// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          String?
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  sessions      Session[]
  accounts      Account[]
  // Last time the user opened their My Submissions list. The account-drawer
  // avatar shows an unseen-count badge for proposals decided after this
  // (design-review D2). Null = never viewed.
  lastSubmissionsViewedAt DateTime?

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ---------------------------------------------------------------------------
// Transit domain — GTFS entities (ids are GTFS ids) + management tables
// ---------------------------------------------------------------------------

enum OperatorCode {
  ANBESSA
  SHEGER
  ALLIANCE
  MINIBUS
  LRT
}

enum FareKind {
  FLAT
  TIERED
}

enum ClosureReason {
  PUBLIC_HOLIDAY
  MAINTENANCE
  POLITICAL_EVENT
  OTHER
}

model Agency {
  id       String  @id
  name     String
  url      String?
  timezone String?
  routes   Route[]

  @@map("agency")
}

model Operator {
  id          String            @id @default(cuid())
  code        OperatorCode      @unique
  name        String
  kind        String // "Fixed-route bus" | "Light rail transit" | "Demand-responsive paratransit"
  assignments RouteAssignment[]

  @@map("operator")
}

model Route {
  id                String   @id
  shortName         String
  longName          String
  type              Int // GTFS route_type: 0 = LRT, 3 = bus
  color             String?
  textColor         String?
  agencyId          String
  agency            Agency   @relation(fields: [agencyId], references: [id])
  // Precomputed LineString geometry: full resolution for detail views,
  // simplified for the all-routes network layer.
  geojson           Json?
  geojsonSimplified Json?
  lengthMeters      Float?

  trips         Trip[]
  fare          Fare?
  closures      RouteClosure[]
  assignment    RouteAssignment?
  proposals     FareProposal[]
  savedBy       SavedRoute[]
  fareChangeLog FareChangeLog[]

  @@index([shortName])
  @@map("route")
}

model Stop {
  id        String     @id
  name      String
  lat       Float
  lon       Float
  stopTimes StopTime[]

  @@index([name])
  @@map("stop")
}

model Trip {
  id          String      @id
  routeId     String
  route       Route       @relation(fields: [routeId], references: [id], onDelete: Cascade)
  serviceId   String
  shapeId     String?
  headsign    String?
  stopTimes   StopTime[]
  frequencies Frequency[]

  @@index([routeId])
  @@map("trip")
}

model StopTime {
  tripId    String
  trip      Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  stopId    String
  stop      Stop   @relation(fields: [stopId], references: [id], onDelete: Cascade)
  sequence  Int
  arrival   String?
  departure String?

  @@id([tripId, sequence])
  @@index([stopId])
  @@map("stop_time")
}

model Frequency {
  id          String @id @default(cuid())
  tripId      String
  trip        Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  startTime   String
  endTime     String
  headwaySecs Int

  @@index([tripId])
  @@map("frequency")
}

model Calendar {
  serviceId String  @id
  monday    Boolean
  tuesday   Boolean
  wednesday Boolean
  thursday  Boolean
  friday    Boolean
  saturday  Boolean
  sunday    Boolean
  startDate String
  endDate   String

  @@map("calendar")
}

model Fare {
  id            String     @id @default(cuid())
  routeId       String     @unique
  route         Route      @relation(fields: [routeId], references: [id], onDelete: Cascade)
  kind          FareKind
  flatAmountEtb Decimal?   @db.Decimal(8, 2)
  currency      String     @default("ETB")
  tiers         FareTier[]
  updatedAt     DateTime   @updatedAt

  @@map("fare")
}

model FareTier {
  id        String  @id @default(cuid())
  fareId    String
  fare      Fare    @relation(fields: [fareId], references: [id], onDelete: Cascade)
  label     String // e.g. "0–4 km", "Short hop"
  fromKm    Float
  toKm      Float? // null = open-ended ("8+ km")
  amountEtb Decimal @db.Decimal(8, 2)

  @@index([fareId])
  @@map("fare_tier")
}

model RouteClosure {
  id          String        @id @default(cuid())
  routeId     String
  route       Route         @relation(fields: [routeId], references: [id], onDelete: Cascade)
  reason      ClosureReason
  note        String?
  startsAt    DateTime
  endsAt      DateTime
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([routeId, startsAt, endsAt])
  @@map("route_closure")
}

model RouteAssignment {
  id           String   @id @default(cuid())
  routeId      String   @unique
  route        Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  operatorId   String
  operator     Operator @relation(fields: [operatorId], references: [id])
  assignedById String? // null when assigned by the seed pipeline
  assignedAt   DateTime @default(now())

  @@index([operatorId])
  @@map("route_assignment")
}

// ---------------------------------------------------------------------------
// Crowdsourced fare registry (design doc: rz-dev-design-20260721)
// ---------------------------------------------------------------------------

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
  // Set on the other pending proposals for a route when one is approved, so
  // every reporter's My Submissions resolves and the queue converges (5A).
  SUPERSEDED
}

enum FareChangeSource {
  PROPOSAL_APPROVAL
  CONSOLE_EDIT
  RESEED
}

// A rider-submitted fare correction for a route. Whole-fare replacement,
// matching updateFare semantics. User ids are plain strings (no FK), like
// RouteClosure.createdById, so the audit trail survives user deletion (1A).
model FareProposal {
  id            String         @id @default(cuid())
  routeId       String
  route         Route          @relation(fields: [routeId], references: [id], onDelete: Cascade)
  submittedById String
  status        ProposalStatus @default(PENDING)
  note          String?

  // Proposed fare (whole-fare replacement).
  proposedKind    FareKind
  proposedFlatEtb Decimal? @db.Decimal(8, 2)
  proposedTiers   Json? // [{label, fromKm, toKm, amountEtb}] when TIERED

  // Snapshot of the fare at submission time, for stable diffs. Nullable: a
  // route may have no Fare row yet ("no fare on record").
  baselineKind    FareKind?
  baselineFlatEtb Decimal? @db.Decimal(8, 2)
  baselineTiers   Json?

  reviewedById String?
  reviewNote   String?
  decidedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([routeId, status])
  @@index([submittedById, createdAt])
  @@map("fare_proposal")
}

model SavedRoute {
  userId    String
  routeId   String
  route     Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, routeId])
  @@index([userId])
  @@map("saved_route")
}

// Append-only audit trail: one row per fare write from any source.
model FareChangeLog {
  id          String           @id @default(cuid())
  routeId     String
  route       Route            @relation(fields: [routeId], references: [id], onDelete: Cascade)
  proposalId  String?
  changedById String
  source      FareChangeSource

  beforeKind    FareKind?
  beforeFlatEtb Decimal?  @db.Decimal(8, 2)
  beforeTiers   Json?
  afterKind     FareKind?
  afterFlatEtb  Decimal?  @db.Decimal(8, 2)
  afterTiers    Json?

  createdAt DateTime @default(now())

  @@index([routeId, createdAt])
  @@map("fare_change_log")
}

enum ValidatorStatus {
  PENDING
  PASS
  WARN
  FAIL
}

// A generated, versioned GTFS export (fares overlay on the base feed).
model FeedVersion {
  id              String          @id @default(cuid())
  version         Int             @unique
  label           String
  filePath        String
  sizeBytes       Int
  fareChangeCount Int             @default(0)
  generatedById   String
  validatorStatus ValidatorStatus @default(PENDING)
  validatorReport Json?
  // Cursor: the newest FareChangeLog id included in this version. The next
  // version's change report lists entries created after this (no time races).
  lastChangeLogId String?
  createdAt       DateTime        @default(now())

  @@map("feed_version")
}
