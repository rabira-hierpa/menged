# Database — Postgres with PostGIS
DATABASE_URL="postgresql://admin:adminpassword@localhost:5432/gtfs_dev_db"

# better-auth — generate with `openssl rand -base64 32`
BETTER_AUTH_SECRET=""
# Public origin of the app (prod: https://your-domain)
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# First user signing in with this email is promoted to super-admin
SUPER_ADMIN_EMAIL=""

# OpenTripPlanner GraphQL endpoint origin
OTP_URL="http://localhost:8081"
